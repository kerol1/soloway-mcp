# SoloWay MCP server config (all optional — defaults shown). See src/config.ts.
PORT=8088
BACKEND_BASE_URL=http://backend:8080
PUBLIC_BASE_URL=https://soloway.com.ua
# CSV of accepted Host values for no-Origin (server-to-server) requests; `*` accepts any host
# and disables the SDK DNS-rebinding belt — sandbox/introspection runs only, NEVER production.
EXPECTED_HOST=mcp.soloway.com.ua
# CSV; wildcards (https://*.claude.ai) are matched by suffix in the originGuard middleware only.
# Provisional — reconcile to the real connector's observed Origin (likely none; server-to-server).
ALLOWED_ORIGINS=https://claude.ai,https://*.claude.ai,https://chatgpt.com,https://*.openai.com,https://soloway.com.ua
SSE_READ_TIMEOUT_MS=39000
SSE_IDLE_TIMEOUT_MS=13000
HTTP_READ_TIMEOUT_MS=12000
SEARCH_MAX_RESULTS=40
SEARCH_MAX_PASSENGERS=10
MCP_MAX_CONCURRENT_SEARCHES=8
MCP_BUSY_WAIT_MS=1500
DEFAULT_LOCALE=uk
CACHE_TTL_AUTOCOMPLETE_MS=3600000
CACHE_TTL_CALENDAR_MS=900000
CACHE_TTL_CALENDAR_PENDING_MS=60000
LOG_LEVEL=info
METRICS_ENABLED=false
NODE_ENV=production
# ChatGPT App domain verification: paste the token from the OpenAI dashboard at submission time.
# Served as plain text at /.well-known/openai-apps-challenge; empty → 404.
OPENAI_APPS_CHALLENGE=
